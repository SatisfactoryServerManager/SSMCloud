{{define "includes/dashboard/nav"}}

<div id="sidebar">
    <nav class="navbar navbar-expand-lg navbar-dark flex-column">
        <div class="navbar-header">
            <a class="navbar-brand" href="/dashboard"
                ><img
                    class="mt-2"
                    src="/public/images/ssm_logo_new_256.svg"
                    alt=""
                    width="64px"
            /></a>

            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav flex-column">
                <li class="nav-item {{if eq .pageTitle "Dashboard"}}active{{end}}">
                    <a class="nav-link" href="/dashboard">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="nav-item {{if or (eq .pageTitle "Servers") (eq .pageTitle "Server")}}active{{end}}">
                    <a class="nav-link" href="/dashboard/servers">
                        <i class="fas fa-server"></i>
                        <span>Servers</span>
                        <span class="nav-pill" id="server-count">{{ len .agents }}</span>
                    </a>
                </li>
                <li class="nav-item {{if eq .pageTitle "Account"}}active{{end}}">
                    <a class="nav-link" href="/dashboard/account">
                        <i class="fas fa-user-shield"></i>
                        <span>Account</span>
                    </a>
                </li>
                <li class="nav-item {{if eq .pageTitle "Integrations"}}active{{end}}">
                    <a class="nav-link" href="/dashboard/integrations">
                        <i class="fa-solid fa-arrows-turn-to-dots"></i>
                        <span>Integrations</span>
                    </a>
                </li>

                <li class="nav-item mt-auto nav-item-bottom">
                    <a class="nav-link" href="/docs" target="_blank">
                        <i class="fas fa-book"></i>
                        <span>Docs</span>
                    </a>
                </li>
                <li class="nav-item dropup sidebar-accounts">
                    <a class="nav-link" href="#" id="sidebarAccountsDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fa-solid fa-building-shield"></i>
                        <span>{{.account.AccountName}}</span>
                        <i class="fas fa-chevron-up caret"></i>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="sidebarAccountsDrop">
                        {{range .linkedAccounts}}
                            <li><a class="dropdown-item" href="/dashboard/account/switch?id={{.Id}}"><i class="fa-solid fa-building-shield me-2"></i> {{.AccountName}}</a></li>
                        {{end}}
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/dashboard/account/create"><i class="fa-solid fa-plus me-2"></i> Create Account</a></li>
                        <li><a class="dropdown-item" href="/dashboard/account/join"><i class="fa-solid fa-right-to-bracket me-2"></i> Join Account</a></li>
                    </ul>
                </li>
                <li class="nav-item dropup sidebar-profile">
                    <a class="nav-link" href="#" id="sidebarProfileDrop" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <img class="profile-image" src="{{.user.ProfileImageUrl}}" alt=""/>
                        <span>{{.user.Username}}</span>
                        <i class="fas fa-chevron-up caret"></i>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="sidebarProfileDrop">
                        <li><a class="dropdown-item" href="/dashboard/profile"><i class="fa-solid fa-user me-2"></i> Profile</a></li>
                        <li>
                            <button type="button" class="dropdown-item sidebar-theme-btn" data-ssm-theme-toggle aria-label="Toggle light/dark theme">
                                <i class="fa-solid fa-circle-half-stroke me-2"></i> Theme
                            </button>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item logout-btn" href="/auth/logout"><i class="fa-solid fa-right-from-bracket me-2"></i> Log Out</a></li>
                    </ul>
                </li>
                <li class="sidebar-status">
                    <span class="status-lamp on"></span> All systems nominal
                </li>
            </ul>
        </div>
    </nav>
</div>

{{ end }}
