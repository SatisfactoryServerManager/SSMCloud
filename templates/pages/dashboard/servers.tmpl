{{define "pages/dashboard/servers"}}
{{template "includes/dashboard/head" .}}

<body>
{{ .csrfField }}
    <div id="viewport" class="minimal">
        {{template "includes/dashboard/nav" .}}
        <div id="content">
            <div class="container-fluid">
                <!-- BODY -->
                <div class="page-container" data-page="dashboard">
                    {{template "includes/dashboard/page-header" .}}

                    <div class="controls-bar">
                        <label class="ssm-search">
                            <i class="fas fa-magnifying-glass"></i>
                            <input type="text" class="server-search" placeholder="Search servers…" aria-label="Search servers">
                        </label>
                        <div class="ssm-filters" id="server-filter">
                            <label class="filter-toggle"><input class="server-filter-checkbox" type="checkbox" id="server-filter-online" checked><span><i class="fas fa-signal"></i> Online</span></label>
                            <label class="filter-toggle"><input class="server-filter-checkbox" type="checkbox" id="server-filter-installed" checked><span><i class="fas fa-box"></i> Installed</span></label>
                            <label class="filter-toggle"><input class="server-filter-checkbox" type="checkbox" id="server-filter-running" checked><span><i class="fas fa-play"></i> Running</span></label>
                        </div>
                        <a href="" class="deploy-btn" id="add-server-btn"><i class="fas fa-plus"></i> Deploy Server</a>
                    </div>

                    {{if not .agents}}
                        <div class="alert alert-info">No servers yet — deploy your first server to bring one online.</div>
                    {{end}}
                    {{if .agents}}
                    <div class="grid" id="serverlist-wrapper">
                        {{range .agents}}
                            {{template "includes/dashboard/small-server-card" .}}
                        {{end}}
                    </div>
                    {{end}}
                </div>
            </div>
        </div>
    </div>
</body>

{{template "includes/dashboard/footer" .}}
{{end}}